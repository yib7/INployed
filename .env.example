# ─────────────────────────────────────────────────────────────────────────────
# Job Scraper — environment configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in your own values.
# `.env` is auto-loaded by scraper.py and the resume tailor when python-dotenv
# is installed (`pip install python-dotenv`). On the GCP VM these are exported
# by run_scraper.sh instead.
#
# Prefer not to edit this by hand? Run `python local/configure.pyw` (or the
# dashboard's Settings tab) to set these keys, paths, and every other option in
# one window. It writes the same .env + config files this section documents.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bright Data (LinkedIn scrape) — REQUIRED to run scraper.py ───────────────
# Get these from your Bright Data dashboard: an API token and the dataset id of
# the LinkedIn jobs dataset you collect from.
BRIGHT_DATA_API_TOKEN=your-bright-data-api-token
BRIGHT_DATA_DATASET_ID=your-bright-data-dataset-id

# ── Google Cloud / Vertex AI (Gemini scoring + resume tailoring) ─────────────
# Project that has Vertex AI enabled and ADC configured (`gcloud auth
# application-default login`). LOCATION is usually "global".
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# ── Resume tailor -- Gemini auth ─────────────────────────────────────────────
# The tailor uses Gemini only. "vertex" (default) bills the Vertex project in
# GOOGLE_CLOUD_PROJECT; "api_key" uses a single Gemini API key (for users without
# a Vertex project). Switchable from the dashboard engine selector, which writes
# local/config.json "gemini_auth".
# RESUME_TAILOR_GEMINI_AUTH=vertex
# Dedicated key for api_key mode. SEPARATE from the classifier's GEMINI_API_KEYS
# pool so the tailor never spends a free-tier pool key. Get one at AI Studio.
# RESUME_TAILOR_GEMINI_API_KEY=
# Name used in generated resume filenames (no spaces -- use underscores).
RESUME_TAILOR_CANDIDATE=Your_Name
# Where generated résumés are written (defaults to ~/Downloads/Generated_Resumes).
# RESUME_TAILOR_OUTPUT=
# Path to pdflatex if it isn't on PATH (MiKTeX/TeX Live).
# PDFLATEX_PATH=pdflatex

# ── Dashboard (optional) ─────────────────────────────────────────────────────
# Chrome profile (by signed-in Google account) to open job links in. Leave blank
# to use the default browser / default Chrome profile.
# LINKEDIN_CHROME_ACCOUNT=

# ── Gemini API key pool (classifier) ─────────────────────────────────────────
# Comma-separated Gemini API keys (no spaces). Three keys from three separate
# Google accounts ~triple the per-project free-tier quota. The classifier rotates
# them (Stage 1 -> gemini-3.1-flash-lite, Stage 2 -> gemini-3.5-flash) and spills
# to the Vertex project above only when all keys are exhausted for the day.
# GEMINI_API_KEYS=key1,key2,key3

# ── Model / cost tuning (optional -- sensible defaults in code) ───────────────
# SCORE_STAGE1_MODEL=gemini-3.1-flash-lite
# SCORE_STAGE2_MODEL=gemini-3.5-flash
# SCORE_STAGE1_CONCURRENCY=6
# SCORE_STAGE2_CONCURRENCY=4
# SCORE_MAX_PER_RUN=800
# SCORE_RESCORE_CAP=200
# RESUME_TAILOR_MODEL_FLASH=gemini-3.5-flash
# RESUME_TAILOR_MODEL_PRO=gemini-3.5-flash      # bump to gemini-3.1-pro-preview for max quality
# RESUME_TAILOR_MODEL_FLASH_LITE=gemini-3.1-flash-lite
