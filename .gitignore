# ── Secrets / credentials ────────────────────────────────────────────────────
.env
# Backups written next to atomically-saved configs (.env.bak holds secrets;
# config.json.bak etc. mirror git-ignored configs); never commit them.
*.bak

# ── Personal / user-supplied content (commit the *.example templates instead) ─
resume.md
resume_tailor_files/master_experience.yaml
# Covers the user's resume_sample.pdf (style example the engine reads via
# config.EXAMPLE_PDF) and any personal resume PDFs kept beside the master.
resume_tailor_files/resume_*.pdf
local/config.json
search_config.json
scoring_config.json
apply_config.json
apply_answers.json

# ── LaTeX build artifacts ────────────────────────────────────────────────────
*.aux
*.log
*.synctex.gz
*.out

# ── Generated / runtime data ─────────────────────────────────────────────────
# seen.db = SQLite application tracker; *.csv covers the scraped job data
# (incl. linkedin_jobs_master.csv); the json/txt below are scraper/scorer run-state.
seen.db
*.csv
*.csv.gz
last_run_job_ids.json
external_exclude_ids.json
score_state.json
company_blocklist.txt
# local scrape rows queued for the VM (deleted after confirmed push)
outbox/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# ── OS / editor / IDE ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Settings snapshots written on every Save. Each snapshot copies the live .env
# (which holds secrets, per the user's "self-contained snapshots" choice), so the
# whole archive must never be committed.
local/settings_archive/

# linked git worktrees (never committed)
.worktrees/
